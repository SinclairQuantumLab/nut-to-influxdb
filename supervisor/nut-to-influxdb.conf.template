; Supervisor config file for program(s)
; copy this file into /etc/supervisor/conf.d/ folder

[program:nut-to-influxdb]
command=/home/<user name>/Projects/nut-to-influxdb/Startup_bash
environment=PYTHONUNBUFFERED=1 ; let stdout logged in real time for python app
user=<user name>
autostart=true
startsecs=5
stdout_logfile=/etc/supervisor/logs/nut-to-influxdb_out.log
stderr_logfile=/etc/supervisor/logs/nut-to-influxdb_err.log
